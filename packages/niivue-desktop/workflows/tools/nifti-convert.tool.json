{
  "$schema": "../schemas/tool.schema.json",
  "name": "nifti-convert",
  "version": "1.0.0",
  "description": "Convert between NIfTI formats and apply basic preprocessing (reorient, resample)",
  "inputs": {
    "input_path": {
      "type": "volume",
      "description": "Input volume path"
    },
    "reorient": {
      "type": "string",
      "description": "Target orientation (e.g., RAS, LPI)",
      "default": "RAS",
      "optional": true
    },
    "resample": {
      "type": "number",
      "description": "Isotropic voxel size in mm",
      "optional": true,
      "min": 0.1,
      "max": 10
    }
  },
  "outputs": {
    "output_path": {
      "type": "volume",
      "description": "Converted volume path"
    }
  },
  "block": {
    "id": "load-nifti",
    "label": "Load NIfTI Files",
    "description": "Load and optionally reorient NIfTI (.nii/.nii.gz) volumes",
    "category": "Import",
    "icon": "FileIcon",
    "defaults": {
      "reorient": "RAS"
    },
    "exposedFields": ["input_path"],
    "hiddenFields": ["reorient", "resample"]
  }
}
